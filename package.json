{
  "name": "flutter-fix-missing-types",
  "repository": {"url": "https://github.com/YofarDev/flutter-fix-missing-types"},
  "displayName": "Flutter Fix Missing Types",
  "description": "To fix missing types in a flutter project that dart fix --apply won't",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flutter-fix-missing-types.fixMissingTypes",
        "title": "Dart: Auto-Fix Missing Types (Current File)"
      },
      {
        "command": "flutter-fix-missing-types.fixProject",
        "title": "Dart: Auto-Fix Missing Types (Whole Project)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
